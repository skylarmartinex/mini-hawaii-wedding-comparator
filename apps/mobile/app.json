    "platforms": ["ios", "android"],
    "ios": {
      "bundleIdentifier": "com.wedding.researchengine",
      "supportsTablet": true
    },
    "android": {
      "package": "com.wedding.researchengine",
      "adaptiveIcon": {
        "backgroundColor": "#0d9488"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
